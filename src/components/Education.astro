---
import Icon from './Icon.astro';

interface EduLink {
  label: string;
  href: string;
}

// A group item can be plain text, or a link (e.g. a course page, a syllabus, an award writeup).
type EduItem = string | EduLink;

interface Degree {
  level: string;
  degree: string;
  school: string;
  years: string;
  focus?: string;
  supervisors?: string[];
  courses?: EduItem[];
  teaching?: EduItem[];
  honors?: EduItem[];
}

interface Props {
  education: Degree[];
}

const { education } = Astro.props;

const isLink = (item: EduItem): item is EduLink => typeof item === 'object';

// Groups are rendered generically so any of them can hold plain tags or links,
// and so a new group (e.g. "Certifications") only needs an entry here.
const GROUPS: { key: 'courses' | 'teaching' | 'honors'; label: string }[] = [
  { key: 'courses', label: 'Coursework' },
  { key: 'teaching', label: 'Teaching' },
  { key: 'honors', label: 'Honors' },
];
---
<section id="education" class="education" data-tape-section data-tape-label="Education">
  <h2 class="eyebrow section-eyebrow">Education</h2>

  <ul class="edu-list">
    {education.map((edu) => (
      <li class="edu-item bracket-frame">
        <details>
          <summary class="edu-summary">
            <span class="edu-level mono">{edu.level}</span>
            <span class="edu-heading">
              <h3 class="edu-degree">{edu.degree}</h3>
              <span class="edu-school mono">{edu.school}</span>
            </span>
            <span class="edu-years mono">{edu.years}</span>
            <Icon name="chevron" class="edu-chevron" />
          </summary>

          <div class="edu-details">
            {edu.focus && <p class="edu-focus">{edu.focus}</p>}

            {edu.supervisors && edu.supervisors.length > 0 && (
              <p class="edu-supervisors mono">Advised by {edu.supervisors.join(', ')}</p>
            )}

            {GROUPS.map(({ key, label }) => {
              const items = edu[key];
              if (!items || items.length === 0) return null;

              return (
                <div class="edu-group">
                  <span class="edu-group-label mono">{label}</span>
                  <ul class="edu-chip-list">
                    {items.map((item) => (
                      <li>
                        {isLink(item) ? (
                          <a
                            class="edu-chip edu-chip--link"
                            href={item.href}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            <span>{item.label}</span>
                            <Icon name="link" class="edu-chip-icon" />
                          </a>
                        ) : (
                          <span class="edu-chip">{item}</span>
                        )}
                      </li>
                    ))}
                  </ul>
                </div>
              );
            })}
          </div>
        </details>
      </li>
    ))}
  </ul>
</section>