---
interface Job {
  year: string;
  title: string;
  department?: string;
  org: string;
  description?: string;
}

interface Props {
  employment: Job[];
}

const { employment } = Astro.props;
---
<section id="employment" class="employment" data-tape-section data-tape-label="Experience">
  <h2 class="eyebrow section-eyebrow">Experience</h2>

  <ul class="employment-list">
    {employment.map((job) => (
      <li class="employment-item bracket-frame">
        <span class="employment-year mono">{job.year}</span>
        <span class="employment-body">
          <h3 class="employment-title">{job.title}</h3>
          <span class="employment-org mono">
            {job.department && <>{job.department} · </>}{job.org}
          </span>
          {job.description && <span class="employment-desc">{job.description}</span>}
        </span>
      </li>
    ))}
  </ul>
</section>