---
import Icon from './Icon.astro';
const cvUpdated = '07/2026';
---
<section class="hero">

  <div class="hero-field" aria-hidden="true">
    <svg class="hero-field-desktop" viewBox="0 0 1200 640" preserveAspectRatio="xMidYMid slice">
      <defs>
        <linearGradient id="flow" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#2955d6" />
          <stop offset="100%" stop-color="#e8c17a" />
        </linearGradient>
        <clipPath id="heroPortraitClip">
          <circle cx="818" cy="316" r="47" />
        </clipPath>
      </defs>

      <!-- streamlines for flow past a cylinder -->
      <g class="streamlines" fill="none" stroke-linecap="round" stroke-width="2">
        <path d="M -49.9 238.2 L 52.6 238.2 L 155.2 238.1 L 278.3 237.8 L 380.8 237.5 L 483.4 236.8 L 606.5 234.5 L 627.0 233.7 L 672.0 231.1 L 679.0 230.5 L 686.1 229.8 L 693.1 229.1 L 700.1 228.3 L 707.1 227.5 L 713.2 226.7 L 720.2 225.8 L 727.2 224.7 L 734.2 223.7 L 741.2 222.5 L 748.3 221.4 L 754.3 220.4 L 761.3 219.3 L 768.3 218.2 L 775.4 217.2 L 782.4 216.3 L 789.4 215.5 L 796.4 214.9 L 802.4 214.4 L 809.5 214.1 L 816.5 214.0 L 823.5 214.0 L 830.5 214.3 L 837.6 214.7 L 843.6 215.2 L 850.6 215.9 L 857.6 216.8 L 864.7 217.7 L 871.7 218.8 L 878.7 219.9 L 885.7 221.0 L 891.7 222.0 L 898.8 223.2 L 905.8 224.3 L 912.8 225.3 L 919.8 226.3 L 926.9 227.3 L 932.9 228.0 L 939.9 228.8 L 946.9 229.5 L 954.0 230.2 L 961.0 230.8 L 968.0 231.4 L 1025.4 234.4 L 1033.6 234.7 L 1066.5 235.6 L 1107.5 236.3 L 1140.3 236.7 L 1181.3 237.1 L 1214.2 237.3 L 1255.2 237.5" stroke="#95a8cc" opacity="0.35" />
