      <!-- cylinder portrait with attitude indicator overlay -->
      <circle cx="818" cy="316" r="47" fill="var(--panel)" />
      <text class="hero-portrait-fallback mono" x="818" y="312" text-anchor="middle" aria-hidden="true">ADD</text>
      <text class="hero-portrait-fallback mono" x="818" y="326" text-anchor="middle" aria-hidden="true">PHOTO</text>
      <image
        href="/airshow.jpg"
        x="771" y="269" width="94" height="94"
        clip-path="url(#heroPortraitClip)"
        preserveAspectRatio="xMidYMid slice"
        aria-label="Portrait of Beverley Yeo"
        onerror="this.setAttribute('opacity', '0')"
      />
      <g transform="translate(818,316) scale(0.6667)" stroke="var(--amber)">
        <circle cx="0" cy="0" r="75" fill="none" stroke-width="2" opacity="0.85" />
        <g stroke-width="1.2" opacity="0.65">
          <line x1="0" y1="-72" x2="0" y2="-64" />
          <line x1="0" y1="64" x2="0" y2="72" />
          <line x1="-72" y1="0" x2="-64" y2="0" />
          <line x1="64" y1="0" x2="72" y2="0" />
          <line x1="-49.4" y1="-49.4" x2="-43.8" y2="-43.8" />
          <line x1="43.8" y1="43.8" x2="49.4" y2="49.4" />
          <line x1="-49.4" y1="49.4" x2="-43.8" y2="43.8" />
          <line x1="43.8" y1="-43.8" x2="49.4" y2="-49.4" />
        </g>
        <path d="M 0 -78 l -7 13 h 14 Z" fill="var(--amber)" opacity="0.9" />
        <line x1="-75" y1="0" x2="75" y2="0" stroke-width="1" stroke-dasharray="3 4" opacity="0.45" />
      </g>
    </svg>

    <!-- mobile portrait -->
    <svg class="hero-field-mobile" viewBox="708 196 220 240" preserveAspectRatio="xMidYMid slice">
      <defs>
        <clipPath id="heroPortraitClipMobile">
          <circle cx="818" cy="316" r="47" />
        </clipPath>
      </defs>
      <circle cx="818" cy="316" r="47" fill="var(--panel)" />
      <text class="hero-portrait-fallback mono" x="818" y="312" text-anchor="middle" aria-hidden="true">ADD</text>
      <text class="hero-portrait-fallback mono" x="818" y="326" text-anchor="middle" aria-hidden="true">PHOTO</text>
      <image
        href="/airshow.jpg"
        x="771" y="269" width="94" height="94"
        clip-path="url(#heroPortraitClipMobile)"
        preserveAspectRatio="xMidYMid slice"
        aria-label="Portrait of Beverley Yeo"
        onerror="this.setAttribute('opacity', '0')"
      />
      <g transform="translate(818,316) scale(0.6667)" stroke="var(--amber)">
        <circle cx="0" cy="0" r="75" fill="none" stroke-width="2" opacity="0.85" />
        <g stroke-width="1.2" opacity="0.65">
          <line x1="0" y1="-72" x2="0" y2="-64" />
          <line x1="0" y1="64" x2="0" y2="72" />
          <line x1="-72" y1="0" x2="-64" y2="0" />
          <line x1="64" y1="0" x2="72" y2="0" />
          <line x1="-49.4" y1="-49.4" x2="-43.8" y2="-43.8" />
          <line x1="43.8" y1="43.8" x2="49.4" y2="49.4" />
          <line x1="-49.4" y1="49.4" x2="-43.8" y2="43.8" />
          <line x1="43.8" y1="-43.8" x2="49.4" y2="-49.4" />
        </g>
        <path d="M 0 -78 l -7 13 h 14 Z" fill="var(--amber)" opacity="0.9" />
        <line x1="-75" y1="0" x2="75" y2="0" stroke-width="1" stroke-dasharray="3 4" opacity="0.45" />
      </g>
    </svg>

    <!-- mobile clouds -->
    <div class="hero-cloud-mobile" aria-hidden="true"></div>
  </div>

  <div class="hero-scrim" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-text">
      <div class="hero-heading">
        <h1>Beverley YEO</h1>
      </div>
      <p class="hero-description">I like GPUs and airplanes, and I work on using GPUs to help airplane designers run faster simulations.</p>
      <ul class="hero-route">
        <li><a href="https://me.stanford.edu">Stanford Mechanical Engineering PhD Candidate</a></li>
        <li><a href="https://www.a-star.edu.sg/Scholarships/for-graduate-studies/national-science-scholarship-phd">A*STAR NSS (PhD) Scholar</a></li>
        <li><a href="https://adl.stanford.edu">Supervised by Prof. Juan Alonso</a></li>
      </ul>
      <div class="hero-actions">
        <a class="hero-action mono has-tooltip" href="/Beverley_CV_PhD.pdf" data-tooltip={`Last updated ${cvUpdated}`}>
          <Icon name="pdf" />
          <span>Download my CV</span>
        </a>
      </div>
    </div>
  </div>

</section>

<div class="hero-cloud-divider" aria-hidden="true"></div>