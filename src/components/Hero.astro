        <path d="M -49.9 346.1 L 52.6 346.1 L 155.2 346.2 L 278.3 346.3 L 380.8 346.4 L 483.4 346.7 L 606.5 347.7 L 627.0 348.1 L 672.0 349.8 L 679.0 350.2 L 686.1 350.7 L 693.1 351.2 L 700.1 351.9 L 707.1 352.7 L 713.2 353.6 L 720.2 354.7 L 727.2 356.2 L 734.2 357.9 L 741.2 360.1 L 748.3 362.6 L 754.3 365.0 L 761.3 368.0 L 768.3 371.0 L 775.4 374.0 L 782.4 376.6 L 789.4 378.9 L 796.4 380.8 L 802.4 381.9 L 809.5 382.8 L 816.5 383.2 L 823.5 383.0 L 830.5 382.4 L 837.6 381.2 L 843.6 379.8 L 850.6 377.7 L 857.6 375.2 L 864.7 372.3 L 871.7 369.3 L 878.7 366.2 L 885.7 363.3 L 891.7 361.1 L 898.8 358.8 L 905.8 356.9 L 912.8 355.3 L 919.8 354.0 L 926.9 353.0 L 932.9 352.2 L 939.9 351.5 L 946.9 350.9 L 954.0 350.4 L 961.0 349.9 L 968.0 349.6 L 1025.4 347.8 L 1033.6 347.7 L 1066.5 347.2 L 1107.5 346.9 L 1140.3 346.7 L 1181.3 346.6 L 1214.2 346.5 L 1255.2 346.4" stroke="url(#flow)" opacity="0.9" />
        <path d="M -49.9 393.8 L 52.6 393.8 L 155.2 393.9 L 278.3 394.2 L 380.8 394.5 L 483.4 395.2 L 606.5 397.5 L 627.0 398.3 L 672.0 400.9 L 679.0 401.5 L 686.1 402.2 L 693.1 402.9 L 700.1 403.7 L 707.1 404.5 L 713.2 405.3 L 720.2 406.2 L 727.2 407.3 L 734.2 408.3 L 741.2 409.5 L 748.3 410.6 L 754.3 411.6 L 761.3 412.7 L 768.3 413.8 L 775.4 414.8 L 782.4 415.7 L 789.4 416.5 L 796.4 417.1 L 802.4 417.6 L 809.5 417.9 L 816.5 418.0 L 823.5 418.0 L 830.5 417.7 L 837.6 417.3 L 843.6 416.8 L 850.6 416.1 L 857.6 415.2 L 864.7 414.3 L 871.7 413.2 L 878.7 412.1 L 885.7 411.0 L 891.7 410.0 L 898.8 408.8 L 905.8 407.7 L 912.8 406.7 L 919.8 405.7 L 926.9 404.7 L 932.9 404.0 L 939.9 403.2 L 946.9 402.5 L 954.0 401.8 L 961.0 401.2 L 968.0 400.6 L 1025.4 397.6 L 1033.6 397.3 L 1066.5 396.4 L 1107.5 395.7 L 1140.3 395.3 L 1181.3 394.9 L 1214.2 394.7 L 1255.2 394.5" stroke="#95a8cc" opacity="0.35" />
