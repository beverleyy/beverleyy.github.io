interface Props {
  name: keyof typeof ICONS;
  class?: string;
}

const { name, class: className = "icon" } = Astro.props;
const icon = ICONS[name];
if (!icon) {
  throw new Error(`Icon: unknown icon name "${name}"`);
}
---
<svg class={className} viewBox={icon.viewBox} aria-hidden="true" set:html={icon.inner} />