---
interface SkillGroup {
  label: string;
  skills: string[];
}

interface Props {
  skillGroups: SkillGroup[];
}

const { skillGroups } = Astro.props;
---
<section id="skills" class="skills" data-tape-section data-tape-label="Skills">
  <h2 class="eyebrow section-eyebrow">Skills</h2>

  <ul class="skill-groups">
    {skillGroups.map((group) => (
      <li class="skill-group bracket-frame">
        <h3 class="skill-group-label mono">{group.label}</h3>
        <div class="skill-tags">
          {group.skills.map((skill) => <span class="mono readout">{skill}</span>)}
        </div>
      </li>
    ))}
  </ul>
</section>